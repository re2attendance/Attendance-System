# Copy to .env.local for development. Every variable here is documented, and
# lib/env.ts validates them at boot — a missing or malformed value fails the
# process on startup rather than surfacing as a null three screens deep.
#
# .env.local is gitignored. This file is not, and must never contain a real
# secret.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────

# Local dev: `pnpm db:start` prints these, and they are identical on every
# machine — Supabase's local stack ships fixed demo credentials. They are not
# secrets and are safe in this file.
#
# Production: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"

# The anon key. NEXT_PUBLIC_, so it reaches the browser — that is correct and
# intended. It carries no authority by itself: every request made with it is
# subject to RLS, and an anonymous caller is refused at the grant layer (0014).
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"

# THE SERVICE ROLE KEY. Bypasses RLS entirely.
#
# NOT NEXT_PUBLIC_. It must never reach a browser. Here it is readable only by
# lib/supabase/admin.ts, which is `import 'server-only'` and ESLint-fenced to
# jobs/* and app/api/cron/* — importing it from app/* is a lint error, verified
# rather than assumed.
#
# In production this is a real secret: rotate it if it ever lands in a client
# bundle, a log, or a screenshot. The value below is the local stack's fixed
# demo key and is public knowledge.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────

# Where this app is reachable. Used to build absolute links in emails and auth
# redirect URLs — Supabase sends users back here after a password reset or an
# email confirmation, so a wrong value breaks those flows quietly.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────────
# Not yet used — listed so the shape of the deploy is visible early
# ─────────────────────────────────────────────────────────────────────────────

# Email (Phase 9). Local dev needs neither: Supabase's stack catches all
# outbound mail in Mailpit at http://127.0.0.1:54324.
# RESEND_API_KEY=""
# RESEND_FROM="Attendance <attendance@example.edu>"

# Rate limiting (Phase 11 per §14). Upstash Redis, fixed window per user+route.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Errors (Phase 11).
# NEXT_PUBLIC_SENTRY_DSN=""

# Protects the cron routes from anyone who finds the URL (Phase 5). Vercel Cron
# sends it as a bearer token.
# CRON_SECRET=""
