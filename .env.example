# Copy to .env.local and fill in. .env.local is gitignored; this file is committed.

# --- Supabase (client-safe) ---
# Project URL and publishable key: Supabase dashboard > Project Settings > API keys.
# Use the modern `sb_publishable_...` key, not the legacy JWT anon key.
# This key is safe to expose ONLY because RLS is correct — which is what the
# pgTAP suite (pnpm db:test) exists to prove.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>

# --- App config (not secret, but re-validated server-side) ---
# Students must sign up as <7-digit-index>@<this domain>.
NEXT_PUBLIC_UNIVERSITY_EMAIL_DOMAIN=upsamail.edu.gh
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only secrets ---
# Salt for device-fingerprint hashing (shared-device detection, Phase 3).
# Generate with: openssl rand -hex 32
DEVICE_HASH_PEPPER=

# SUPABASE_SERVICE_ROLE_KEY is intentionally NOT listed. It bypasses RLS entirely.
# Privileged writes go through SECURITY DEFINER functions instead. If you find
# yourself needing this key, stop and reconsider the design.
